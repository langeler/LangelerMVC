# APPLICATION
APP_NAME=LangelerMVC
APP_ENV=production
APP_DEBUG=false
APP_INSTALLED=false
APP_URL=http://localhost
APP_TIMEZONE=Europe/Stockholm
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_VERSION=1.0.0
APP_MAINTENANCE=false
APP_LOG_LEVEL=info
APP_LOG_CHANNEL=daily

# DATABASE
DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=Storage/Database/langelermvc.sqlite
DB_USERNAME=
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_POOLING=false
DB_POOL_SIZE=10
DB_FAILOVER=
DB_TIMEOUT=30
DB_RETRY_DELAY=2000
DB_SSL_MODE=prefer
DB_REPLICATION=false

# MAIL
MAIL_MAILER=array
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@langelermvc.test
MAIL_FROM_NAME=LangelerMVC
MAIL_REPLY_TO=no-reply@langelermvc.test
MAIL_CC=
MAIL_BCC=
MAIL_QUEUE=false
MAIL_LOG_ENABLED=true

# SESSION
SESSION_DRIVER=database
SESSION_NAME=langelermvc_session
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_SECURE_COOKIE=true
SESSION_HTTPONLY_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_SAVE_PATH=Storage/Sessions

# CACHE
CACHE_ENABLED=true
CACHE_DRIVER=file
CACHE_PREFIX=langelermvc_cache
CACHE_TTL=3600
CACHE_COMPRESSION=true
CACHE_SERIALIZATION=php
CACHE_ENCRYPT=false
CACHE_REDIS_HOST=127.0.0.1
CACHE_REDIS_PORT=6379
CACHE_REDIS_PASSWORD=
CACHE_REDIS_DATABASE=0
CACHE_MEMCACHED_HOST=127.0.0.1
CACHE_MEMCACHED_PORT=11211
CACHE_FILE_PATH=Storage/Cache

# ENCRYPTION
ENCRYPTION_ENABLED=true
ENCRYPTION_TYPE=openssl
ENCRYPTION_KEY=base64:YourGlobalEncryptionKeyHere
ENCRYPTION_CIPHER=AES-256-CBC
ENCRYPTION_HASH_ALGO=bcrypt
ENCRYPTION_HASH_ROUNDS=12
ENCRYPTION_OPENSSL_KEY=base64:YourOpenSSLEncryptionKeyHere
ENCRYPTION_OPENSSL_CIPHER=AES-256-CBC
ENCRYPTION_SODIUM_KEY=base64:YourSodiumKeyHere

# FEATURES
FEATURE_VERIFY_EMAIL=true
FEATURE_2FA=true

# PAYMENTS
PAYMENT_DRIVER=testing

# WEBMODULE
WEBMODULE_CONTENT_SOURCE=database
