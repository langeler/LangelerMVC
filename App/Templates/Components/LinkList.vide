@php
$links = is_array($links ?? null) ? $links : [];
$label = (string) ($label ?? 'Related links');
@endphp
@if($links !== [])
    <nav class="link-list" aria-label="{{ $label }}">
        @foreach($links as $link)
            @if(is_array($link) && ($link['href'] ?? '') !== '' && ($link['label'] ?? '') !== '')
                <a href="{{ (string) $link['href'] }}">{{ (string) $link['label'] }}</a>
            @endif
        @endforeach
    </nav>
@endif
