                'rows' => array_map(static fn(array $app): array => [
                    'label' => (string) ($app['label'] ?? ''),
                    'platforms' => implode(', ', (array) ($app['platforms'] ?? [])),
                    'note' => (string) ($app['note'] ?? ''),
                ], $trackingApps),
                'empty' => 'No tracking apps are currently suggested for this order.',
