     */\
    abstract protected function verify(string $signature): bool;\
\
    /**\
     * Generate a hash.\
     * \
     * @return string\
     * @throws CryptoException\
     */\
    abstract protected function hash(): string;\
\
    /**\
     * Derive a cryptographic key.\
     * \
     * @param string $salt\
     * @return string\
     * @throws CryptoException\
     */\
    abstract protected function deriveKey(string $salt): string;\
\}}