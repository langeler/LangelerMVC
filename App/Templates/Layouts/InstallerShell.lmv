<!DOCTYPE html>
<html lang="en" data-theme="{{ (string) ($themeName ?? 'bootstrap-light') }}" data-theme-mode="{{ (string) ($themeMode ?? 'system') }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ $pageTitle ?? 'Install LangelerMVC' }}</title>
    <style>
        :root {
            --bg: #f7f4ed;
            --paper: #fffdf7;
            --ink: #173426;
            --muted: #63796d;
            --line: #d8d2c1;
            --accent: #195d48;
            --accent-soft: #dfeee7;
            --danger: #a03d2f;
            --danger-soft: #f9e2dd;
            --shadow: 0 22px 50px rgba(23, 52, 38, 0.12);
        }

        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", serif;
            color: var(--ink);
            background:
                radial-gradient(circle at top left, rgba(25, 93, 72, 0.16), transparent 30%),
                linear-gradient(180deg, #faf7f0 0%, var(--bg) 100%);
        }
        a { color: var(--accent); }
        .shell {
            width: min(1180px, calc(100vw - 32px));
            margin: 32px auto;
            display: grid;
            gap: 24px;
        }
        .hero,
        .panel {
            background: var(--paper);
            border: 1px solid rgba(23, 52, 38, 0.08);
            box-shadow: var(--shadow);
            border-radius: 28px;
        }
        .hero {
            padding: 32px;
            display: grid;
            gap: 12px;
        }
        .hero p,
        .panel p,
        .panel li,
        .panel label,
        .panel input,
        .panel select,
        .panel textarea,
        .panel button {
            font-family: "Avenir Next", "Segoe UI", sans-serif;
        }
        .eyebrow {
            text-transform: uppercase;
            letter-spacing: 0.14em;
            font-size: 12px;
            color: var(--muted);
            margin: 0;
        }
        h1, h2, h3 {
            margin: 0;
            line-height: 1.05;
            font-weight: 700;
        }
        h1 { font-size: clamp(2.4rem, 4vw, 4rem); max-width: 12ch; }
        .hero-copy { max-width: 72ch; color: var(--muted); font-size: 1rem; line-height: 1.65; }
        .hero-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 14px;
            margin-top: 8px;
        }
        .hero-card {
            border-radius: 20px;
            padding: 16px;
            background: linear-gradient(180deg, rgba(25, 93, 72, 0.08), rgba(25, 93, 72, 0.03));
            border: 1px solid rgba(25, 93, 72, 0.12);
        }
        .hero-card strong {
            display: block;
            margin-bottom: 6px;
            font-family: "Avenir Next", "Segoe UI", sans-serif;
            font-size: 14px;
        }
        .panel { padding: 28px; }
        .layout {
            display: grid;
            grid-template-columns: minmax(0, 2.1fr) minmax(300px, 0.9fr);
            gap: 24px;
        }
        .stack { display: grid; gap: 24px; }
        .status-grid,
        .provider-grid,
        .field-grid {
            display: grid;
            gap: 14px;
        }
        .status-grid,
        .provider-grid { grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); }
        .field-grid { grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
        .status-card,
        .provider-card {
            border: 1px solid var(--line);
            border-radius: 20px;
            padding: 16px;
            background: rgba(255,255,255,0.72);
        }
        .status-card strong,
        .provider-card strong {
            display: block;
            margin-bottom: 6px;
            font-size: 14px;
        }
        .status-ok { color: var(--accent); font-weight: 700; }
        .status-bad { color: var(--danger); font-weight: 700; }
        form { display: grid; gap: 24px; }
        [hidden] { display: none !important; }
        .section-head { display: grid; gap: 6px; margin-bottom: 18px; }
        .section-head p { margin: 0; color: var(--muted); }
        .step-kicker {
            text-transform: uppercase;
            letter-spacing: 0.16em;
            font-size: 11px;
            font-weight: 800;
            color: var(--accent);
        }
        .installer-guide {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
            gap: 12px;
            margin-bottom: 22px;
        }
        .installer-guide > div {
            display: grid;
            gap: 6px;
            padding: 15px;
            border: 1px solid rgba(25, 93, 72, 0.12);
            border-radius: 18px;
            background:
                linear-gradient(135deg, rgba(25, 93, 72, 0.10), rgba(25, 93, 72, 0.02)),
                rgba(255, 255, 255, 0.68);
        }
        .installer-guide strong {
            font-family: "Avenir Next", "Segoe UI", sans-serif;
            font-size: 14px;
        }
        .installer-guide span {
            color: var(--muted);
            font-family: "Avenir Next", "Segoe UI", sans-serif;
            font-size: 13px;
            line-height: 1.55;
        }
        .installer-stepper {
            position: sticky;
            top: 12px;
            z-index: 3;
            display: none;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 8px;
            padding: 8px;
            border: 1px solid var(--line);
            border-radius: 22px;
            background: color-mix(in srgb, var(--paper) 92%, white);
            box-shadow: 0 14px 35px rgba(23, 52, 38, 0.10);
        }
        .installer-form--enhanced .installer-stepper { display: grid; }
        .step-tab {
            display: flex;
            align-items: center;
            gap: 8px;
            min-height: 44px;
            padding: 8px 10px;
            border: 1px solid transparent;
            border-radius: 16px;
            background: transparent;
            color: var(--muted);
            text-align: left;
            cursor: pointer;
        }
        .step-tab span {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 28px;
            height: 28px;
            border-radius: 999px;
            background: rgba(25, 93, 72, 0.08);
            color: var(--accent);
            font-size: 12px;
            font-weight: 800;
        }
        .step-tab strong {
            font-size: 13px;
            line-height: 1.1;
        }
        .step-tab.is-active,
        .step-tab:hover {
            background: var(--accent-soft);
            border-color: rgba(25, 93, 72, 0.18);
            color: var(--accent);
        }
        .installer-progress {
            display: none;
            height: 8px;
            overflow: hidden;
            border-radius: 999px;
            background: rgba(25, 93, 72, 0.10);
        }
        .installer-form--enhanced .installer-progress { display: block; }
        .installer-progress span {
            display: block;
            width: 12.5%;
            height: 100%;
            border-radius: inherit;
            background: linear-gradient(90deg, var(--accent), #57a584);
            transition: width 180ms ease;
        }
        .installer-progress-copy {
            display: none;
            margin: -10px 0 0;
            color: var(--muted);
            font-size: 13px;
        }
        .installer-form--enhanced .installer-progress-copy { display: block; }
        .installer-step-panel {
            display: grid;
            gap: 16px;
            padding: 22px;
            border: 1px solid rgba(25, 93, 72, 0.10);
            border-radius: 24px;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0.54)),
                rgba(255, 255, 255, 0.62);
        }
        .field {
            display: grid;
            gap: 8px;
        }
        .field label {
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--muted);
            font-weight: 700;
        }
        .field input,
        .field select,
        .field textarea {
            width: 100%;
            border-radius: 16px;
            border: 1px solid var(--line);
            padding: 14px 16px;
            background: white;
            color: var(--ink);
            font-size: 15px;
        }
        .field textarea { min-height: 110px; resize: vertical; }
        .field small { color: var(--muted); }
        .field-inline {
            display: flex;
            gap: 12px;
            align-items: center;
            flex-wrap: wrap;
            padding: 12px 14px;
            border: 1px solid var(--line);
            border-radius: 16px;
            background: white;
        }
        .field-inline label {
            text-transform: none;
            letter-spacing: 0;
            font-size: 14px;
            color: var(--ink);
            display: flex;
            gap: 8px;
            align-items: center;
        }
        .actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            align-items: center;
        }
        .installer-step-actions [data-installer-prev],
        .installer-step-actions [data-installer-next] {
            display: none;
        }
        .installer-form--enhanced .installer-step-actions [data-installer-prev],
        .installer-form--enhanced .installer-step-actions [data-installer-next] {
            display: inline-flex;
        }
        .button {
            appearance: none;
            border: 0;
            border-radius: 999px;
            padding: 14px 22px;
            background: var(--accent);
            color: white;
            font-weight: 700;
            letter-spacing: 0.04em;
            cursor: pointer;
        }
        .button.secondary {
            background: transparent;
            color: var(--accent);
            border: 1px solid rgba(25, 93, 72, 0.18);
        }
        .button:disabled {
            cursor: not-allowed;
            opacity: 0.55;
            transform: none;
        }
        .notice {
            padding: 16px 18px;
            border-radius: 18px;
            font-family: "Avenir Next", "Segoe UI", sans-serif;
        }
        .notice.error {
            background: var(--danger-soft);
            color: var(--danger);
        }
        .notice.success {
            background: var(--accent-soft);
            color: var(--accent);
        }
        .summary-list {
            display: grid;
            gap: 10px;
            padding: 0;
            margin: 0;
            list-style: none;
        }
        .summary-list li {
            display: flex;
            justify-content: space-between;
            gap: 16px;
            border-bottom: 1px dashed var(--line);
            padding-bottom: 10px;
        }
        .summary-list span:last-child {
            color: var(--muted);
            text-align: right;
        }
        .muted { color: var(--muted); }
        @media (max-width: 960px) {
            .layout { grid-template-columns: 1fr; }
            .shell { margin: 18px auto; width: min(100vw - 18px, 1180px); }
            .hero, .panel { padding: 22px; border-radius: 22px; }
            .installer-stepper { position: static; grid-template-columns: repeat(2, minmax(0, 1fr)); }
            .installer-step-panel { padding: 18px; }
        }
        @media (max-width: 560px) {
            .installer-stepper { grid-template-columns: 1fr; }
            .step-tab { min-height: 40px; }
        }
    </style>
    <link rel="stylesheet" href="{{ (string) ($themeAssetCss ?? '/assets/css/langelermvc-theme.css') }}">
</head>
<body class="theme-surface theme-surface--{{ (string) ($themeSurface ?? 'installer') }} {{ (string) ($themeClass ?? 'theme-bootstrap-light') }}"
      data-theme="{{ (string) ($themeName ?? 'bootstrap-light') }}"
      data-theme-mode="{{ (string) ($themeMode ?? 'system') }}"
      data-theme-default-mode="{{ (string) ($themeDefaultMode ?? 'system') }}"
      data-theme-storage-key="{{ (string) ($themeStorageKey ?? 'langelermvc.theme') }}">
<main class="shell">
    <section class="hero">
        <p class="eyebrow">Framework Installation</p>
        <h1>{{ $pageTitle ?? 'Install LangelerMVC' }}</h1>
        <p class="hero-copy">
            Configure the platform once, provision the database-backed starter modules, and finish with a ready-to-use administrator account.
            This wizard keeps the setup inside the framework instead of sending you through manual config editing and command juggling.
        </p>
        @if($themeToggleEnabled ?? true)
            <div class="theme-header-actions">
                <span class="muted">Theme: {{ (string) ($themeLabel ?? 'Bootstrap Light') }}</span>
                <button type="button" class="theme-toggle" data-theme-toggle aria-label="Toggle color theme" aria-pressed="false">
                    <span data-theme-toggle-label>{{ ucfirst((string) ($themeMode ?? 'system')) }}</span>
                </button>
            </div>
        @endif
        <div class="hero-grid">
            <article class="hero-card">
                <strong>Framework-native setup</strong>
                Uses the same runtime, migration, seed, auth, and payment abstractions the framework uses in production.
            </article>
            <article class="hero-card">
                <strong>Commerce-ready baseline</strong>
                Seeds Web, User, Shop, Cart, and Order modules so the platform is usable immediately after install.
            </article>
            <article class="hero-card">
                <strong>Secure defaults</strong>
                Starts with database-backed content, database sessions, production-focused cookie settings, and testing payment mode.
            </article>
        </div>
    </section>

    {!! $content ?? '' !!}
</main>
<script>
    (() => {
        const form = document.querySelector('[data-installer-form]');

        if (!form) {
            return;
        }

        const panels = Array.from(form.querySelectorAll('[data-installer-step-panel]'));
        const triggers = Array.from(form.querySelectorAll('[data-installer-step-trigger]'));
        const previous = form.querySelector('[data-installer-prev]');
        const next = form.querySelector('[data-installer-next]');
        const submit = form.querySelector('[data-installer-submit]');
        const progressBar = form.querySelector('[data-installer-progress-bar]');
        const progressText = form.querySelector('[data-installer-progress-text]');

        if (panels.length === 0 || triggers.length === 0) {
            return;
        }

        form.classList.add('installer-form--enhanced');

        let activeIndex = 0;

        const clamp = (value) => Math.max(0, Math.min(value, panels.length - 1));
        const stepTitle = (index) => panels[index]?.getAttribute('data-step-title') || `Step ${index + 1}`;

        const showStep = (index, shouldFocus) => {
            activeIndex = clamp(index);

            panels.forEach((panel, panelIndex) => {
                const isActive = panelIndex === activeIndex;
                panel.hidden = !isActive;
                panel.classList.toggle('is-active', isActive);
            });

            triggers.forEach((trigger, triggerIndex) => {
                const isActive = triggerIndex === activeIndex;
                trigger.classList.toggle('is-active', isActive);
                trigger.setAttribute('aria-current', isActive ? 'step' : 'false');
            });

            if (progressBar) {
                progressBar.style.width = `${((activeIndex + 1) / panels.length) * 100}%`;
            }

            if (progressText) {
                progressText.textContent = `Section ${activeIndex + 1} of ${panels.length}: ${stepTitle(activeIndex)}`;
            }

            if (previous) {
                previous.disabled = activeIndex === 0;
            }

            if (next) {
                next.hidden = activeIndex === panels.length - 1;
            }

            if (submit) {
                submit.hidden = activeIndex !== panels.length - 1;
            }

            if (shouldFocus) {
                panels[activeIndex].scrollIntoView({ behavior: 'smooth', block: 'start' });
                const focusTarget = panels[activeIndex].querySelector('input:not([type="hidden"]), select, textarea, button');

                if (focusTarget) {
                    focusTarget.focus({ preventScroll: true });
                }
            }
        };

        triggers.forEach((trigger) => {
            trigger.addEventListener('click', () => {
                showStep(Number.parseInt(trigger.getAttribute('data-installer-step-trigger') || '0', 10), true);
            });
        });

        previous?.addEventListener('click', () => showStep(activeIndex - 1, true));
        next?.addEventListener('click', () => showStep(activeIndex + 1, true));

        form.addEventListener('invalid', (event) => {
            const field = event.target;

            if (!(field instanceof HTMLElement)) {
                return;
            }

            const panel = field.closest('[data-installer-step-panel]');
            const index = panels.indexOf(panel);

            if (index >= 0) {
                showStep(index, false);
            }
        }, true);

        showStep(0, false);
    })();
</script>
<script src="{{ (string) ($themeAssetJs ?? '/assets/js/langelermvc-theme.js') }}" defer></script>
</body>
</html>
