{
    "name": "langeler/mvc",
    "description": "LangelerMVC is a custom-built PHP MVC framework focused on structure, modularity, and maintainable backend architecture.",
    "type": "project",
    "license": "MIT",
    "homepage": "https://github.com/langeler/LangelerMVC",
    "keywords": [
        "php",
        "mvc",
        "framework",
        "custom",
        "modular",
        "oop",
        "srp",
        "soc",
        "php84"
    ],
    "authors": [
        {
            "name": "Joakim Langeler",
            "homepage": "https://github.com/langeler",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "vlucas/phpdotenv": "^5.6",
        "phpmailer/phpmailer": "^7.0",
        "paragonie/constant_time_encoding": "^3.1",
        "spomky-labs/otphp": "^11.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "App/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "Tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0"
    },
    "scripts": {
        "test": "phpunit --testdox",
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "developer": {
            "name": "Joakim Langeler",
            "github": "https://github.com/langeler"
        },
        "project": {
            "github": "https://github.com/langeler/LangelerMVC",
            "description": "LangelerMVC is a custom-built PHP MVC framework designed with a strong focus on structure, modularity, and best practices, including SRP, SoC, and OOP principles.",
            "status": "Core runtime, console, schema lifecycle, session drivers, cache, crypto, SQL/query, validation, MVC, and utility subsystems implemented and regression-tested; WebModule starter slice completed; additional business modules scaffolded.",
            "topics": [
                "php",
                "mvc",
                "framework",
                "custom",
                "modular",
                "oop",
                "srp",
                "soc",
                "php84"
            ],
            "support": {
                "issues": "https://github.com/langeler/LangelerMVC/issues",
                "source": "https://github.com/langeler/LangelerMVC",
                "docs": "https://github.com/langeler/LangelerMVC/wiki"
            },
            "funding": {
                "type": "github",
                "url": "https://github.com/sponsors/langeler"
            },
            "license": "MIT"
        }
    },
    "support": {
        "issues": "https://github.com/langeler/LangelerMVC/issues",
        "source": "https://github.com/langeler/LangelerMVC",
        "docs": "https://github.com/langeler/LangelerMVC/wiki"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/langeler"
        }
    ]
}
