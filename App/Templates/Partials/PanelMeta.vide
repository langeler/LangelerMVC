@php
$items = is_array($items ?? null) ? $items : [];
$items = array_filter(
    $items,
    static fn(mixed $value): bool => $value !== null && $value !== ''
);
@endphp
@if($items !== [])
    <div class="meta">
        @foreach($items as $label => $value)
            <span>{{ (string) $label }}: {{ $value }}</span>
        @endforeach
    </div>
@endif
