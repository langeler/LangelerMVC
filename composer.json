{
    "name": "langeler/mvc",
    "description": "Personal Project: PHP MVC Framework built on PHP 8.4+",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "vlucas/phpdotenv": "^5.6",
        "phpmailer/phpmailer": "^7.0",
        "paragonie/constant_time_encoding": "^3.1",
        "spomky-labs/otphp": "^11.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "App/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0"
    },
    "scripts": {
        "test": "phpunit --testdox",
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "developer": {
            "name": "Joakim Langeler",
            "github": "https://github.com/langeler"
        },
        "project": {
            "github": "https://github.com/langeler/LangelerMVC",
            "description": "A PHP 8.4+ MVC Project. Focusing on structure, adhering to the Single Responsibility Principle, Separation of Concerns, and Object-Oriented Programming (OOP).",
            "status": "Development ongoing",
            "topics": [
                "php",
                "development",
                "sql",
                "mvc",
                "pdo",
                "custom",
                "oop",
                "srp",
                "soc",
                "php8",
                "php84"
            ],
            "support": {
                "issues": "https://github.com/langeler/LangelerMVC/issues",
                "source": "https://github.com/langeler/LangelerMVC",
                "docs": "https://github.com/langeler/LangelerMVC/wiki"
            },
            "funding": {
                "type": "github",
                "url": "https://github.com/sponsors/langeler"
            },
            "license": "MIT"
        }
    },
    "support": {
        "issues": "https://github.com/langeler/LangelerMVC/issues",
        "source": "https://github.com/langeler/LangelerMVC",
        "docs": "https://github.com/langeler/LangelerMVC/wiki"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/langeler"
        }
    ]
}
