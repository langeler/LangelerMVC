                <select name="shipping_option">
                    @foreach((array) ($shipping['options'] ?? []) as $option)
                        <option value="{{ (string) ($option['code'] ?? '') }}"@selected(($checkout['shipping_option'] ?? $shipping['selected_option'] ?? '') === ($option['code'] ?? ''))>
                            {{ (string) ($option['label'] ?? 'Shipping') }} - {{ (string) ($option['effective_rate'] ?? $option['rate'] ?? '') }}
                        </option>
                    @endforeach
                </select>
