                            $row = is_array($entitlement) ? $entitlement : [];
                            $limit = (int) ($row['download_limit'] ?? 0);
                            $used = (int) ($row['downloads_used'] ?? 0);
                        @endphp
                        <tr>
                            <td>
                                @if(!empty($row['access_path']))
                                    <a href="{{ (string) $row['access_path'] }}">{{ (string) ($row['label'] ?? 'Access content') }}</a>
                                @else
                                    {{ (string) ($row['label'] ?? 'Access content') }}
                                @endif
                            </td>
                            <td>{{ (string) ($row['type'] ?? '') }}</td>
                            <td>{{ (string) ($row['status'] ?? '') }}</td>
                            <td>{{ $limit > 0 ? $used . ' / ' . $limit : 'Unlimited' }}</td>
                            <td>{{ (string) ($row['starts_at'] ?? '') }} @if(!empty($row['expires_at'])) to {{ (string) $row['expires_at'] }} @endif</td>
                        </tr>
                    @endforeach
                </tbody>
            </table>
        </div>
