            <label>
                Payment method
                <select name="payment_method">
                    @foreach((array) ($payment['supported_methods'] ?? []) as $method)
                        <option value="{{ (string) $method }}"@selected(($checkout['payment_method'] ?? $payment['default_method'] ?? '') === $method)>
