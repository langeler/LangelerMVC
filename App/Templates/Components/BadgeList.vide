@php
$items = is_array($items ?? null) ? $items : [];
$empty = (string) ($empty ?? '');
@endphp
@if($items === [])
    @if($empty !== '')
        <p>{{ $empty }}</p>
    @endif
@else
    <ul class="badge-list">
        @foreach($items as $item)
            <li>{{ $item }}</li>
        @endforeach
    </ul>
@endif
