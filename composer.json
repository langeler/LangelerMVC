{
    "name": "langeler/mvc",
    "description": "LangelerMVC is a custom-built PHP MVC framework focused on structure, modularity, and maintainable backend architecture.",
    "type": "project",
    "license": "MIT",
    "homepage": "https://github.com/langeler/LangelerMVC",
    "keywords": [
        "php",
        "mvc",
        "framework",
        "custom",
        "modular",
        "oop",
        "srp",
        "soc",
        "php84"
    ],
    "authors": [
        {
            "name": "Joakim Langeler",
            "homepage": "https://github.com/langeler",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "paragonie/constant_time_encoding": "^3.1",
        "phpmailer/phpmailer": "^7.0",
        "spomky-labs/otphp": "^11.4",
        "vlucas/phpdotenv": "^5.6",
        "web-auth/webauthn-lib": "^5.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "App/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "Tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0"
    },
    "scripts": {
        "test": "phpunit --testdox",
        "test:sqlite": "@test",
        "test:db-matrix": "phpunit -c phpunit.db-matrix.xml --testdox",
        "test:mysql": "LANGELER_DB_MATRIX_TARGET=mysql phpunit -c phpunit.db-matrix.xml --testdox",
        "test:pgsql": "LANGELER_DB_MATRIX_TARGET=pgsql phpunit -c phpunit.db-matrix.xml --testdox",
        "test:sqlsrv": "LANGELER_DB_MATRIX_TARGET=sqlsrv phpunit -c phpunit.db-matrix.xml --testdox",
        "ops:health": "@php console health:check live",
        "ops:ready": "@php console health:check ready",
        "ops:audit": "@php console audit:list --limit=25",
        "verify:platform": [
            "@test",
            "@ops:health"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "developer": {
            "name": "Joakim Langeler",
            "github": "https://github.com/langeler"
        },
        "project": {
            "github": "https://github.com/langeler/LangelerMVC",
            "description": "LangelerMVC is a custom-built PHP MVC framework designed with a strong focus on structure, modularity, and best practices, including SRP, SoC, and OOP principles.",
            "status": "Runtime, console, migrations/seeds, session/auth/RBAC, TOTP/passkeys, cache, crypto, SQL/query, async, notifications, payment compatibility flows, presentation, admin, WebModule, ShopModule, CartModule, and OrderModule are implemented and regression-tested; DB-matrix harness is available for MySQL/PostgreSQL/SQL Server verification.",
            "topics": [
                "php",
                "mvc",
                "framework",
                "custom",
                "modular",
                "oop",
                "srp",
                "soc",
                "php84",
                "totp",
                "webauthn",
                "queue",
                "notifications",
                "payments"
            ],
            "support": {
                "issues": "https://github.com/langeler/LangelerMVC/issues",
                "source": "https://github.com/langeler/LangelerMVC",
                "docs": "https://github.com/langeler/LangelerMVC/wiki"
            },
            "funding": {
                "type": "github",
                "url": "https://github.com/sponsors/langeler"
            },
            "license": "MIT"
        }
    },
    "support": {
        "issues": "https://github.com/langeler/LangelerMVC/issues",
        "source": "https://github.com/langeler/LangelerMVC",
        "docs": "https://github.com/langeler/LangelerMVC/wiki"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/langeler"
        }
    ]
}
