            <label>
                Service point ID
                <input type="text" name="service_point_id" value="{{ (string) ($checkout['service_point_id'] ?? $shipping['service_point_id'] ?? '') }}" placeholder="Optional for locker/service point deliveries">
            </label>

            <label>
                Service point name
                <input type="text" name="service_point_name" value="{{ (string) ($checkout['service_point_name'] ?? $shipping['service_point_name'] ?? '') }}" placeholder="Optional delivery point name">
